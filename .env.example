# Copy to .env and fill in secrets. Loaded automatically from the working directory.

# --- JIRA (required) ---
# Base URL with no trailing path, e.g. https://imh-internal.atlassian.net
JIRA_BASE_URL=https://imh-internal.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# Deploy subtask type: set NAME or ID (at least one required).
JIRA_DEPLOY_ISSUE_TYPE_NAME=Deploy
# JIRA_DEPLOY_ISSUE_TYPE_ID=

# Case-insensitive substring in summary for R&T bucket (non-Deploy issues from today's filter).
JIRA_RT_SUMMARY_CONTAINS=Review & Test

# R&T approval (☑️): your issue comment must include this as a heading (or equivalent line).
# JIRA rich text “Heading” style, or a line like ## Testing Completed / **Testing Completed**.
JIRA_RT_APPROVED_COMMENT_HEADER=Testing Completed

# If email is hidden on comments, set your Atlassian account id so “your” comments match.
# JIRA_COMMENT_AUTHOR_ACCOUNT_ID=

# Saved filter IDs (defaults match the Steady automation plan).
FILTER_TODAY_ID=12992
FILTER_TOMORROW_DEV_ID=12990
FILTER_TOMORROW_DEPLOY_ID=12561

# --- Calendar (exactly one of ICAL_PATH or ICAL_URL) ---
#
# Local .ics (leave ICAL_URL unset): refreshed by you or cron; Google’s full export
# from Settings → Import & export often includes real titles even when the secret URL does not.
# ICAL_PATH=/home/you/.cache/steady/calendar.ics
#
# Secret HTTP feed (leave ICAL_PATH unset): Calendar → Integrate calendar → Secret iCal address.
# ICAL_URL=
#
# Automating the file: Google does not ship “export today/tomorrow only” on a schedule.
# Practical options: (1) cron + curl of ICAL_URL into ICAL_PATH (same privacy as the URL);
# (2) Calendar API or gcalcli + OAuth writing an .ics or JSON for a date range (full titles);
# (3) manual periodic export → save → point ICAL_PATH at that file.
ICAL_URL=

# --- Timezone ---
# IANA zone used for “today” and calendar interpretation.
STEADY_TIMEZONE=America/Chicago

# Substring in calendar event title that marks an R&T block (#review, show JIRA R&T section).
CAL_RT_EVENT_SUBSTRING=R&T

# Email matched against ICS ATTENDEE mailto: for PARTSTAT (defaults to JIRA_EMAIL).
# CALENDAR_USER_EMAIL=you@example.com

# When true (default): omit events where your PARTSTAT is DECLINED or TENTATIVE (No / Maybe).
# CAL_FILTER_ATTENDEE_RESPONSE=false

# Include all-day events in meeting lists and R&T detection (default: off).
# STEADY_INCLUDE_ALL_DAY_MEETINGS=false

# When true, drop calendar events whose title contains CAL_RT_EVENT_SUBSTRING from meeting lists
# (so R&T does not duplicate under Non-Development).
# STEADY_MEETINGS_EXCLUDE_RT_EVENTS=false

# Shown under **Development** for tomorrow when filter 12990 is empty.
# STEADY_NEW_TICKET_MESSAGE=Picking up a new ticket.
